<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#000000">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="CheeseJam">
  <link rel="manifest" href="/manifest.json">
  <meta name="description" content="Browse and transpose ChordPro songs from Google Drive.">
  <title>{{config.title}}</title>
  <style>
    html { height: 100%; }
    body {
      background: #2F3131;
      color: #f8f8f8;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      min-height: 100%;
    }
    #root { min-height: 100vh; }
    .App-loading { color: #ffae00; padding: 1.25rem; text-align: center; }
    .App-error {
      background: #4a2020;
      color: #ffbdbd;
      font-size: 0.85rem;
      margin: 0;
      padding: 0.75rem 1rem;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .Header__site-name a { color: #ffae00; text-decoration: none; }
    .SongBrowser { background: #fff; color: #2F3131; }
  </style>
</head>
<body>
<noscript>
  You need to enable JavaScript to run this app.
</noscript>
<p class="App-loading" id="appLoading">Loading CheeseJam…</p>
<pre class="App-error" id="appBootError" hidden></pre>
<script>
(function () {
  function showError(message) {
    var loading = document.getElementById('appLoading');
    var error = document.getElementById('appBootError');
    if (loading) loading.hidden = true;
    if (error) {
      error.hidden = false;
      error.textContent = message;
    }
  }
  window.addEventListener('error', function (event) {
    showError(event.message || 'Script error');
  });
  window.addEventListener('unhandledrejection', function (event) {
    showError(String(event.reason && event.reason.message ? event.reason.message : event.reason));
  });
})();
</script>
<div id="root">
  <div class="App SongBrowserApp">
    <header class="Header">
      <div class="Header__wrapper">
        <h1 class="Header__site-name">
          <a href="{{config.publicUrl}}">{{config.title}}</a>
        </h1>
        <ul class="Header__navigation">
          <li class="GoogleAuth" id="googleAuth">
            <span class="GoogleAuth__user" id="googleAuth__userLabel"></span>
            <button type="button" id="googleAuth__signIn">Sign in with Google</button>
            <button type="button" id="googleAuth__signOut" hidden>Sign out</button>
          </li>
        </ul>
      </div>
    </header>
    <main class="App__container">
      <div class="App__columns">
        <section class="SongBrowser" id="songBrowser">
          <div class="SongBrowser__header">
            <h2 class="SongBrowser__title">Library</h2>
            <p class="SongBrowser__breadcrumb" id="songBrowser__breadcrumb">Songs</p>
            <div class="SongBrowser__filters">
              <input
                type="search"
                class="SongBrowser__search"
                id="songBrowser__search"
                placeholder="Search title, artist, file…"
                autocomplete="off"
              >
              <div class="SongBrowser__scope" id="songBrowser__scope">
                <label class="SongBrowser__scope-option">
                  <input type="radio" name="songBrowserScope" value="folder" checked>
                  This folder
                </label>
                <label class="SongBrowser__scope-option">
                  <input type="radio" name="songBrowserScope" value="all">
                  All songs
                </label>
              </div>
              <div class="SongBrowser__tags" id="songBrowser__tags" hidden></div>
            </div>
            <div class="SongBrowser__toolbar SongBrowser__toolbar--nav">
              <button class="SongBrowser__back-button" id="songBrowser__backButton" type="button" disabled>Up</button>
              <button class="SongBrowser__clear-button" id="songBrowser__clearButton" type="button" hidden>Clear search</button>
            </div>
          </div>
          <p class="SongBrowser__index-status" id="songBrowser__indexStatus" aria-live="polite"></p>
          <p class="SongBrowser__status" id="songBrowser__status" hidden></p>
          <div class="SongBrowser__list" id="songBrowser__list"></div>
          <div class="SongBrowser__song-actions">
            <p class="SongBrowser__song-actions-label" id="songBrowser__selectionLabel">Select a song to rename or delete</p>
            <div class="SongBrowser__toolbar SongBrowser__toolbar--song">
              <button class="SongBrowser__file-button" id="songBrowser__renameButton" type="button" disabled>Rename</button>
              <button class="SongBrowser__file-button" id="songBrowser__matchTitleButton" type="button" disabled>Match title</button>
              <button class="SongBrowser__file-button SongBrowser__file-button--delete" id="songBrowser__deleteButton" type="button" disabled>Delete</button>
            </div>
          </div>
        </section>
        <section class="App__column App__column--editor">
          <div class="App__row App__row--grow App__row--relative">
            <div class="EditorToolbar" id="toolbar">
              <div class="EditorToolbar__group">
                <span class="EditorToolbar__label">Create</span>
                <ul class="Toolbar">
                  <li><button id="toolbar__newSong" type="button">New</button></li>
                  <li><button id="toolbar__importUrl" type="button">Import URL</button></li>
                </ul>
              </div>
              <div class="EditorToolbar__group">
                <span class="EditorToolbar__label">Song</span>
                <ul class="Toolbar">
                  <li><button id="toolbar__viewSong" type="button">View</button></li>
                  <li><button id="toolbar__saveSong" type="button">Save to Drive</button></li>
                </ul>
              </div>
              <div class="EditorToolbar__group">
                <span class="EditorToolbar__label">Chords</span>
                <ul class="Toolbar">
                  <li><button id="toolbar__transposeDown" type="button">Transpose down</button></li>
                  <li><button id="toolbar__transposeUp" type="button">Transpose up</button></li>
                  <li><button id="toolbar__switchToSharp" type="button">Use ♯</button></li>
                  <li><button id="toolbar__switchToFlat" type="button">Use ♭</button></li>
                </ul>
              </div>
            </div>
            <div class="EditorContainer">
              <div class="ChordSheetEditor EditorContainer__editor" id="chordSheetEditor">
                <script type="text/template"></script>
              </div>
            </div>
            <div class="EditorContainer__errorMessage" id="chordSheetEditor__errorMessage"></div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div class="Toast" id="toast" role="status" aria-live="polite">
    <p class="Toast__message" id="toast__message"></p>
  </div>
</div>

<dialog class="ImportDialog" id="importDialog">
  <form class="ImportDialog__form" id="importDialog__form">
    <h2 class="ImportDialog__title">Import from URL</h2>
    <p class="ImportDialog__hint">Paste a link to a web page with chord or tab data.</p>
    <input
      type="url"
      class="ImportDialog__url"
      id="importDialog__url"
      placeholder="https://…"
      autocomplete="off"
      required
    >
    <p class="ImportDialog__error" id="importDialog__error" hidden></p>
    <div class="ImportDialog__actions">
      <button type="button" id="importDialog__cancel">Cancel</button>
      <button type="submit" id="importDialog__import">Import</button>
    </div>
  </form>
</dialog>

<section class="FullscreenViewer" id="fullscreenViewer" hidden>
  <div class="FullscreenViewer__outlet ChordSheetViewer" id="fullscreenViewer__outlet"></div>
  <button
    type="button"
    class="FullscreenViewer__columns"
    id="fullscreenViewer__columns"
    aria-label="Switch to two columns"
    title="Two columns"
    hidden
  >2 col</button>
  <button
    type="button"
    class="FullscreenViewer__close"
    id="fullscreenViewer__close"
    aria-label="Close view"
    title="Close view (Esc)"
  >×</button>
</section>
<script src="{{bundlePath}}"></script>
</body>
</html>
