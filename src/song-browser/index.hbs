<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="theme-color" content="#000000">
  <meta name="description" content="Browse and transpose ChordPro songs from Google Drive.">
  <title>{{config.title}}</title>
  <style>
    html { height: 100%; }
    body {
      background: #2F3131;
      color: #f8f8f8;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      min-height: 100%;
    }
    #root { min-height: 100vh; }
    .App-loading { color: #ffae00; padding: 1.25rem; text-align: center; }
    .App-error {
      background: #4a2020;
      color: #ffbdbd;
      font-size: 0.85rem;
      margin: 0;
      padding: 0.75rem 1rem;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .Header__site-name a { color: #ffae00; text-decoration: none; }
    .SongBrowser { background: #fff; color: #2F3131; }
  </style>
</head>
<body>
<noscript>
  You need to enable JavaScript to run this app.
</noscript>
<p class="App-loading" id="appLoading">Loading CheeseJam…</p>
<pre class="App-error" id="appBootError" hidden></pre>
<script>
(function () {
  function showError(message) {
    var loading = document.getElementById('appLoading');
    var error = document.getElementById('appBootError');
    if (loading) loading.hidden = true;
    if (error) {
      error.hidden = false;
      error.textContent = message;
    }
  }
  window.addEventListener('error', function (event) {
    showError(event.message || 'Script error');
  });
  window.addEventListener('unhandledrejection', function (event) {
    showError(String(event.reason && event.reason.message ? event.reason.message : event.reason));
  });
})();
</script>
<div id="root">
  <div class="App SongBrowserApp">
    <header class="Header">
      <div class="Header__wrapper">
        <h1 class="Header__site-name">
          <a href="{{config.publicUrl}}">{{config.title}}</a>
        </h1>
        <ul class="Header__navigation">
          <li class="GoogleAuth" id="googleAuth">
            <span class="GoogleAuth__user" id="googleAuth__userLabel"></span>
            <button type="button" id="googleAuth__signIn">Sign in with Google</button>
            <button type="button" id="googleAuth__signOut" hidden>Sign out</button>
          </li>
        </ul>
      </div>
    </header>
    <main class="App__container">
      <div class="App__columns">
        <section class="SongBrowser" id="songBrowser">
          <div class="SongBrowser__header">
            <h2 class="SongBrowser__title">Library</h2>
            <p class="SongBrowser__breadcrumb" id="songBrowser__breadcrumb">Songs</p>
            <div class="SongBrowser__filters">
              <input
                type="search"
                class="SongBrowser__search"
                id="songBrowser__search"
                placeholder="Search title, artist, file…"
                autocomplete="off"
              >
              <div class="SongBrowser__scope" id="songBrowser__scope">
                <label class="SongBrowser__scope-option">
                  <input type="radio" name="songBrowserScope" value="folder" checked>
                  This folder
                </label>
                <label class="SongBrowser__scope-option">
                  <input type="radio" name="songBrowserScope" value="all">
                  All songs
                </label>
              </div>
              <div class="SongBrowser__tags" id="songBrowser__tags" hidden></div>
            </div>
            <div class="SongBrowser__toolbar">
              <button class="SongBrowser__back-button" id="songBrowser__backButton" type="button" disabled>Up</button>
              <button class="SongBrowser__clear-button" id="songBrowser__clearButton" type="button" hidden>Clear</button>
            </div>
          </div>
          <p class="SongBrowser__index-status" id="songBrowser__indexStatus" aria-live="polite"></p>
          <p class="SongBrowser__status" id="songBrowser__status"></p>
          <div class="SongBrowser__list" id="songBrowser__list"></div>
        </section>
        <section class="App__column App__column--editor">
          <div class="App__row App__row--grow App__row--relative">
            <ul class="Toolbar" id="toolbar">
              {{#each config.toolbar}}
                <li>
                  <button id="toolbar__{{@key}}" type="button">{{this}}</button>
                </li>
              {{/each}}
            </ul>
            <div class="EditorContainer">
              <div class="ChordSheetEditor EditorContainer__editor" id="chordSheetEditor" data-mode="text">
                <script type="text/template"></script>
              </div>
            </div>
            <div class="EditorContainer__errorMessage" id="chordSheetEditor__errorMessage"></div>
          </div>
        </section>
        <section class="App__column App__column--viewer" id="chordSheetViewer">
          <div class="ChordSheetViewer__toolbar">
            <ul class="RadioGroup">
              {{#each config.displayModes}}
                <li class="RadioGroup__option">
                  <input
                    type="radio"
                    class="RadioGroup__radio"
                    id="chordSheetViewer__displayMode{{upperCaseFirst @key}}"
                    name="display_mode"
                    value="{{@key}}"
                    {{#if (eq ../config.defaultDisplayMode @key)}}
                      checked="checked"
                    {{/if}}
                  >
                  <label
                    class="RadioGroup__label"
                    for="chordSheetViewer__displayMode{{upperCaseFirst @key}}"
                  >{{this}}</label>
                </li>
              {{/each}}
            </ul>
            <button
              type="button"
              class="ChordSheetViewer__toolbar__fullscreen"
              id="chordSheetViewer__fullscreen"
              disabled
            >Fullscreen</button>
          </div>
          <div class="ChordSheetViewer" id="chordSheetViewer__outlet"></div>
        </section>
      </div>
    </main>
  </div>

  <div class="Toast" id="toast" role="status" aria-live="polite">
    <p class="Toast__message" id="toast__message"></p>
  </div>
</div>

<section class="FullscreenViewer" id="fullscreenViewer" hidden>
  <div class="FullscreenViewer__outlet ChordSheetViewer" id="fullscreenViewer__outlet"></div>
  <button
    type="button"
    class="FullscreenViewer__close"
    id="fullscreenViewer__close"
    aria-label="Exit fullscreen"
    title="Exit fullscreen (Esc)"
  >×</button>
</section>
<script src="{{bundlePath}}"></script>
</body>
</html>
