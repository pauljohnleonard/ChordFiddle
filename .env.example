# Google OAuth client ID (Web application) — identity only, no Drive scope in the browser
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com

# Path to service account JSON key (create in Google Cloud → IAM → Service Accounts)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Root song library folder in Google Drive
DRIVE_FOLDER_ID=1s7QKTXKAUdl2W1Zn6oiQOG1Q6EA6lmZX

# API server port
API_PORT=3001
